rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ================================
    // FUNÇÕES AUXILIARES
    // ================================
    
    // Verificar se o utilizador está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verificar se o utilizador é o dono do documento
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
      // ================================
    // VERIFICAÇÃO DE ADMIN (Suporta Quest4You + Quest4Couple)
    // ================================
    
    // Verifica se existe na coleção admins (partilhada) - método principal
    function isAdminByCollection() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Fallback: verifica campo isAdmin/role no perfil Quest4You (1 read)
    function isAdminInQuest4You() {
      let user = get(/databases/$(database)/documents/quest4you_users/$(request.auth.uid));
      return user != null && (user.data.isAdmin == true || user.data.role == 'admin');
    }
    
    // Fallback: verifica campo isAdmin/role no perfil Quest4Couple (1 read)
    function isAdminInQuest4Couple() {
      let user = get(/databases/$(database)/documents/quest4couple_users/$(request.auth.uid));
      return user != null && (user.data.isAdmin == true || user.data.role == 'admin');
    }
    
    // Função principal — curto-circuito: admins collection primeiro (1 read),
    // só vai ao perfil se necessário (máx 3 reads no total)
    function isAdmin() {
      return isAuthenticated() && (isAdminByCollection() || isAdminInQuest4You() || isAdminInQuest4Couple());
    }
      // ================================
    // UTILIZADORES (users) - Coleção antiga
    // ================================
    match /users/{userId} {
      // Qualquer pessoa pode ler perfis públicos
      allow read: if true;
      // Só o próprio utilizador pode escrever no seu perfil
      allow write: if isOwner(userId);
      
      // Subcoleções Quest4Couple
      match /answers/{answerId} {
        allow write: if isAuthenticated() && request.auth.uid == userId;
        allow read: if isAuthenticated();
      }
      match /customQuestions/{packId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /progress/{progressId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /connections/{connectionId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // ================================
    // UTILIZADORES (quest4you_users) - Quest4You
    // ================================
    match /quest4you_users/{userId} {
      // Admins podem ler todos os perfis
      // Utilizadores autenticados podem ler perfis (para buscar nicknames e SmartMatch)
      allow read: if isAuthenticated();
      // Só o próprio utilizador pode criar o seu perfil
      allow create: if isOwner(userId);
      // O próprio utilizador OU admins podem atualizar
      allow update: if isOwner(userId) || isAdmin();
      // Admins podem eliminar utilizadores
      allow delete: if isAdmin();
    }
    
    // ================================
    // UTILIZADORES (quest4couple_users) - Quest4Couple
    // ================================
    match /quest4couple_users/{userId} {
      // Admins podem ler todos os perfis
      // Utilizadores autenticados podem ler perfis (para buscar nicknames e SmartMatch)
      allow read: if isAuthenticated();
      // Só o próprio utilizador pode criar o seu perfil
      allow create: if isOwner(userId);
      // O próprio utilizador OU admins podem atualizar
      allow update: if isOwner(userId) || isAdmin();
      // Admins podem eliminar utilizadores
      allow delete: if isAdmin();
    }
    
    // ================================
    // VALIDAÇÃO DE GÉNERO (genderValidations)
    // ================================
    match /genderValidations/{validationId} {
      // Admins podem ler TODAS as validações (para listagem no painel)
      // Utilizadores podem ler a sua própria validação
      allow read: if isAuthenticated();
      // Utilizadores autenticados podem criar pedidos de validação
      allow create: if isAuthenticated();
      // Utilizadores podem atualizar a sua própria validação (até ser revista)
      // Admins podem atualizar qualquer validação
      allow update: if isAuthenticated() && 
        (isAdmin() || (resource.data.userId == request.auth.uid && resource.data.status == 'pending'));
      // Apenas admins podem apagar validações
      allow delete: if isAdmin();
    }
    
    // ================================
    // ADMINS (admins)
    // ================================
    match /admins/{userId} {
      // Qualquer utilizador autenticado pode verificar se é admin
      allow read: if isAuthenticated();
      // Ninguém pode escrever via app (gerido manualmente no console)
      allow write: if false;
    }
    
    // ================================
    // ARTIGOS PERSONALIZADOS (quest4you_articles)
    // ================================
    match /quest4you_articles/{articleId} {
      // Qualquer pessoa pode ler artigos
      allow read: if true;
      // Só admins podem criar/editar/apagar artigos
      allow write: if isAdmin();
    }
    
    // ================================
    // COMENTÁRIOS EM ARTIGOS (quest4you_comments)
    // ================================
    match /quest4you_comments/{commentId} {
      // Qualquer pessoa pode ler comentários
      allow read: if true;
      // Utilizadores autenticados podem criar comentários
      allow create: if isAuthenticated();
      // Só o autor ou admin pode editar/apagar
      allow update, delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // TÓPICOS DO FÓRUM (quest4you_topics)
    // ================================
    match /quest4you_topics/{topicId} {
      // Qualquer pessoa pode ler tópicos
      allow read: if true;
      // Utilizadores autenticados podem criar tópicos
      allow create: if isAuthenticated();
      // Qualquer utilizador autenticado pode atualizar (para incrementar replyCount)
      allow update: if isAuthenticated();
      // Só o autor ou admin pode apagar
      allow delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // RESPOSTAS DO FÓRUM (quest4you_replies)
    // ================================
    match /quest4you_replies/{replyId} {
      // Qualquer pessoa pode ler respostas
      allow read: if true;
      // Utilizadores autenticados podem criar respostas
      allow create: if isAuthenticated();
      // Autor ou admin pode editar/apagar
      allow update, delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // MENSAGENS DO CHAT PÚBLICO (quest4you_chat)
    // ================================
    match /quest4you_chat/{messageId} {
      // Qualquer pessoa pode ler mensagens do chat
      allow read: if true;
      // Utilizadores autenticados podem enviar mensagens
      allow create: if isAuthenticated();
      // Só admin pode apagar mensagens
      allow update, delete: if isAdmin();
    }
      // ================================
    // CONVERSAS PRIVADAS (quest4you_conversations)
    // ================================
    match /quest4you_conversations/{conversationId} {
      // Só participantes podem ler a conversa
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      // Utilizadores autenticados podem criar conversas
      allow create: if isAuthenticated();
      // Só participantes podem atualizar
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      // Só participantes podem apagar conversas (cleanup de duplicados)
      allow delete: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
    }
    
    // ================================
    // MENSAGENS PRIVADAS (quest4you_messages)
    // ================================
    match /quest4you_messages/{messageId} {
      // Utilizadores autenticados podem ler mensagens
      allow read: if isAuthenticated();
      // Utilizadores autenticados podem criar mensagens
      allow create: if isAuthenticated();
      // Ninguém pode editar/apagar mensagens privadas
      allow update, delete: if false;
    }
    
    // ================================
    // NOTIFICAÇÕES (quest4you_notifications)
    // ================================
    match /quest4you_notifications/{notificationId} {
      // Só o destinatário pode ler as suas notificações
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      // Utilizadores autenticados podem criar notificações para outros
      allow create: if isAuthenticated();
      // Só o destinatário pode atualizar (marcar como lida)
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      // Só o destinatário pode apagar
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // ================================
    // QUIZZES (para futuras funcionalidades)
    // ================================
    match /quizResults/{resultId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    // ================================
    // MATCHES (Smart Match)
    // ================================
    match /matches/{matchId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.users;
      allow write: if isAuthenticated();
    }
    
    // ================================
    // ================================
    // QUEST4COUPLE - COLEÇÕES ESPECÍFICAS
    // ================================
    // ================================
    
    // ================================
    // ARTIGOS PERSONALIZADOS (quest4couple_articles)
    // ================================
    match /quest4couple_articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ================================
    // COMENTÁRIOS (quest4couple_comments)
    // ================================
    match /quest4couple_comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // TÓPICOS DO FÓRUM (quest4couple_topics)
    // ================================
    match /quest4couple_topics/{topicId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // RESPOSTAS DO FÓRUM (quest4couple_replies)
    // ================================
    match /quest4couple_replies/{replyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // CHAT PÚBLICO (quest4couple_chat)
    // ================================
    match /quest4couple_chat/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // ================================
    // CONVERSAS PRIVADAS (quest4couple_conversations)
    // ================================
    match /quest4couple_conversations/{conversationId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      allow delete: if false;
    }
    
    // ================================
    // MENSAGENS PRIVADAS (quest4couple_messages)
    // ================================
    match /quest4couple_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    // ================================
    // VALIDAÇÃO DE GÉNERO QUEST4COUPLE
    // ================================
    match /quest4couple_genderValidations/{validationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (isAdmin() || (resource.data.userId == request.auth.uid && resource.data.status == 'pending'));
      allow delete: if isAdmin();
    }
    
    // ================================
    // FEEDBACK (partilhado ou separado)
    // ================================
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    match /quest4you_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    match /quest4couple_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // ================================
    // SISTEMA DE AMIZADES (quest4you_friendships)
    // ================================
    match /quest4you_friendships/{friendshipId} {
      // Utilizadores podem ler amizades onde estão envolvidos
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
      // Utilizadores autenticados podem criar pedidos de amizade
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid;
      // Só o receiver pode aceitar/rejeitar, ou sender pode cancelar
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.receiverId || 
         request.auth.uid == resource.data.senderId);
      // Ambos podem remover a amizade
      allow delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
    }
    
    // Sub-coleção para lista de amigos (cache rápido)
    match /quest4you_users/{userId}/friends/{friendId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isOwner(friendId);
    }
    
    // ================================
    // SISTEMA DE BLOQUEIO (quest4you_blocks)
    // ================================
    match /quest4you_blocks/{blockId} {
      // Utilizadores podem ler os seus próprios bloqueios
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.blockerId || isAdmin());
      // Utilizadores autenticados podem criar bloqueios
      allow create: if isAuthenticated() && 
        request.resource.data.blockerId == request.auth.uid;
      // Só quem bloqueou pode remover o bloqueio
      allow update, delete: if isAuthenticated() && 
        request.auth.uid == resource.data.blockerId;
    }
    
    // ================================
    // DENÚNCIAS (quest4you_reports)
    // ================================
    match /quest4you_reports/{reportId} {
      // Admins podem ler todas as denúncias
      allow read: if isAdmin();
      // Utilizadores autenticados podem criar denúncias
      allow create: if isAuthenticated();
      // Só admins podem atualizar/resolver denúncias
      allow update, delete: if isAdmin();
    }
    
    // ================================
    // GRUPOS DE CHAT (quest4you_groups)
    // ================================
    match /quest4you_groups/{groupId} {
      // Participantes e admins podem ler
      allow read: if isAuthenticated() && 
        (request.auth.uid in resource.data.participants || isAdmin());
      // Utilizadores autenticados podem criar grupos
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants;
      // Participantes podem atualizar (mensagens, etc)
      // Admins do grupo podem editar detalhes
      allow update: if isAuthenticated() && 
        (request.auth.uid in resource.data.participants || isAdmin());
      // Apenas admins do grupo ou admins gerais podem eliminar
      allow delete: if isAuthenticated() && 
        (request.auth.uid in resource.data.admins || isAdmin());
    }
    
    // ================================
    // HISTÓRICO DE MATCHES (quest4you_match_history)
    // ================================
    match /quest4you_match_history/{matchId} {
      // Utilizadores podem ler o seu próprio histórico
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      // Utilizadores autenticados podem criar matches
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // Utilizadores podem atualizar/eliminar o seu próprio histórico
      allow update, delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
    }
    
    // ================================
    // PEDIDOS DE VERIFICAÇÃO (quest4you_verification_requests)
    // ================================
    match /quest4you_verification_requests/{requestId} {
      // Utilizadores podem ver os seus próprios pedidos, admins vêem todos
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      // Utilizadores autenticados podem criar pedidos
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // Admins podem atualizar/resolver pedidos
      allow update: if isAdmin();
      // Admins podem eliminar pedidos processados
      allow delete: if isAdmin();
    }
      // ================================
    // BROADCASTS (quest4you_broadcasts)
    // ================================
    match /quest4you_broadcasts/{broadcastId} {
      // Admins podem ler histórico de broadcasts
      allow read: if isAdmin();
      // Apenas admins podem criar broadcasts
      allow create: if isAdmin();
      // Broadcasts são imutáveis após criação
      allow update, delete: if false;
    }
    
    // ================================
    // ================================
    // QUEST4COUPLE - COLEÇÕES ORIGINAIS DO V2
    // (Coleções que usam a estrutura antiga users/{userId}/...)
    // ================================
    // ================================
      // ================================
    // RESPONSES (Quest4Couple)
    // ================================
    match /responses/{responseId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
    
    // ================================
    // CONNECTIONS (Quest4Couple - raiz)
    // ================================
    match /connections/{connectionId} {
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.users;
      allow read: if isAuthenticated() && request.auth.uid in resource.data.users;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.users;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.users;
    }
    
    // ================================
    // CONNECTION REQUESTS (Quest4Couple)
    // ================================
    match /connection_requests/{requestId} {
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.fromUserId;
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.toUserId;
      allow delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
    }
    
    // ================================
    // ACTIVITIES (Quest4Couple)
    // ================================
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ================================
    // PARTNERS (Quest4Couple)
    // ================================
    match /partners/{partnerId} {
      allow create, read, update: if isAuthenticated();
      allow delete: if false;
    }
    
    // ================================
    // PARTNER CONNECTIONS (Quest4Couple)
    // ================================
    match /partnerConnections/{connectionId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ================================
    // USER ANSWERS (Quest4Couple)
    // ================================
    match /userAnswers/{docId} {
      allow read, write: if isAuthenticated() && request.auth.uid == docId;
    }
    
    // ================================
    // ANALYTICS (Quest4Couple)
    // ================================
    match /analytics_full_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    
    match /analytics_answers/{answerId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    
    // ================================
    // AUDIT LOG (Quest4Couple)
    // ================================
    match /audit_log/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    
    // ================================
    // PUBLIC STATISTICS (Quest4Couple)
    // ================================
    match /publicStatistics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ================================
    // QUEST4YOU - QUIZ RESULTS (usado pelo Quest4Couple para Quest4You)
    // ================================
    match /quest4you_results/{resultId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ================================
    // QUEST4YOU - PUBLIC PROFILES (Smart Match)
    // ================================
    match /quest4you_public/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == profileId;
      allow update, delete: if isAuthenticated() && request.auth.uid == profileId;
    }
    
    // ================================
    // NOTIFICAÇÕES (quest4couple_notifications)
    // ================================
    match /quest4couple_notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
