rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ================================
    // FUNÇÕES AUXILIARES
    // ================================
    
    // Verificar se o utilizador está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verificar se o utilizador é o dono do documento
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ================================
    // VERIFICAÇÃO DE ADMIN (Suporta Quest4You + Quest4Couple)
    // ================================
    
    // Verifica se existe na coleção admins (partilhada)
    function isAdminByCollection() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Verifica admin no Quest4You
    function isAdminInQuest4You() {
      return exists(/databases/$(database)/documents/quest4you_users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/quest4you_users/$(request.auth.uid)).data.isAdmin == true ||
         get(/databases/$(database)/documents/quest4you_users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Verifica admin no Quest4Couple
    function isAdminInQuest4Couple() {
      return exists(/databases/$(database)/documents/quest4couple_users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/quest4couple_users/$(request.auth.uid)).data.isAdmin == true ||
         get(/databases/$(database)/documents/quest4couple_users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Função principal para verificar admin (ambos os projetos)
    function isAdmin() {
      return isAuthenticated() && (isAdminByCollection() || isAdminInQuest4You() || isAdminInQuest4Couple());
    }
    
    // ================================
    // UTILIZADORES (users) - Coleção antiga
    // ================================
    match /users/{userId} {
      // Qualquer pessoa pode ler perfis públicos
      allow read: if true;
      // Só o próprio utilizador pode escrever no seu perfil
      allow write: if isOwner(userId);
    }
    
    // ================================
    // UTILIZADORES (quest4you_users) - Quest4You
    // ================================
    match /quest4you_users/{userId} {
      // Admins podem ler todos os perfis
      // Utilizadores autenticados podem ler perfis (para buscar nicknames e SmartMatch)
      allow read: if isAuthenticated();
      // Só o próprio utilizador pode criar o seu perfil
      allow create: if isOwner(userId);
      // O próprio utilizador OU admins podem atualizar
      allow update: if isOwner(userId) || isAdmin();
      // Admins podem eliminar utilizadores
      allow delete: if isAdmin();
    }
    
    // ================================
    // UTILIZADORES (quest4couple_users) - Quest4Couple
    // ================================
    match /quest4couple_users/{userId} {
      // Admins podem ler todos os perfis
      // Utilizadores autenticados podem ler perfis (para buscar nicknames e SmartMatch)
      allow read: if isAuthenticated();
      // Só o próprio utilizador pode criar o seu perfil
      allow create: if isOwner(userId);
      // O próprio utilizador OU admins podem atualizar
      allow update: if isOwner(userId) || isAdmin();
      // Admins podem eliminar utilizadores
      allow delete: if isAdmin();
    }
    
    // ================================
    // VALIDAÇÃO DE GÉNERO (genderValidations)
    // ================================
    match /genderValidations/{validationId} {
      // Admins podem ler TODAS as validações (para listagem no painel)
      // Utilizadores podem ler a sua própria validação
      allow read: if isAuthenticated();
      // Utilizadores autenticados podem criar pedidos de validação
      allow create: if isAuthenticated();
      // Utilizadores podem atualizar a sua própria validação (até ser revista)
      // Admins podem atualizar qualquer validação
      allow update: if isAuthenticated() && 
        (isAdmin() || (resource.data.userId == request.auth.uid && resource.data.status == 'pending'));
      // Apenas admins podem apagar validações
      allow delete: if isAdmin();
    }
    
    // ================================
    // ADMINS (admins)
    // ================================
    match /admins/{userId} {
      // Qualquer utilizador autenticado pode verificar se é admin
      allow read: if isAuthenticated();
      // Ninguém pode escrever via app (gerido manualmente no console)
      allow write: if false;
    }
    
    // ================================
    // ARTIGOS PERSONALIZADOS (quest4you_articles)
    // ================================
    match /quest4you_articles/{articleId} {
      // Qualquer pessoa pode ler artigos
      allow read: if true;
      // Só admins podem criar/editar/apagar artigos
      allow write: if isAdmin();
    }
    
    // ================================
    // COMENTÁRIOS EM ARTIGOS (quest4you_comments)
    // ================================
    match /quest4you_comments/{commentId} {
      // Qualquer pessoa pode ler comentários
      allow read: if true;
      // Utilizadores autenticados podem criar comentários
      allow create: if isAuthenticated();
      // Só o autor ou admin pode editar/apagar
      allow update, delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // TÓPICOS DO FÓRUM (quest4you_topics)
    // ================================
    match /quest4you_topics/{topicId} {
      // Qualquer pessoa pode ler tópicos
      allow read: if true;
      // Utilizadores autenticados podem criar tópicos
      allow create: if isAuthenticated();
      // Qualquer utilizador autenticado pode atualizar (para incrementar replyCount)
      allow update: if isAuthenticated();
      // Só o autor ou admin pode apagar
      allow delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // RESPOSTAS DO FÓRUM (quest4you_replies)
    // ================================
    match /quest4you_replies/{replyId} {
      // Qualquer pessoa pode ler respostas
      allow read: if true;
      // Utilizadores autenticados podem criar respostas
      allow create: if isAuthenticated();
      // Autor ou admin pode editar/apagar
      allow update, delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // MENSAGENS DO CHAT PÚBLICO (quest4you_chat)
    // ================================
    match /quest4you_chat/{messageId} {
      // Qualquer pessoa pode ler mensagens do chat
      allow read: if true;
      // Utilizadores autenticados podem enviar mensagens
      allow create: if isAuthenticated();
      // Só admin pode apagar mensagens
      allow update, delete: if isAdmin();
    }
    
    // ================================
    // CONVERSAS PRIVADAS (quest4you_conversations)
    // ================================
    match /quest4you_conversations/{conversationId} {
      // Só participantes podem ler a conversa
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      // Utilizadores autenticados podem criar conversas
      allow create: if isAuthenticated();
      // Só participantes podem atualizar
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      // Ninguém pode apagar conversas
      allow delete: if false;
    }
    
    // ================================
    // MENSAGENS PRIVADAS (quest4you_messages)
    // ================================
    match /quest4you_messages/{messageId} {
      // Utilizadores autenticados podem ler mensagens
      allow read: if isAuthenticated();
      // Utilizadores autenticados podem criar mensagens
      allow create: if isAuthenticated();
      // Ninguém pode editar/apagar mensagens privadas
      allow update, delete: if false;
    }
    
    // ================================
    // QUIZZES (para futuras funcionalidades)
    // ================================
    match /quizResults/{resultId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    // ================================
    // MATCHES (Smart Match)
    // ================================
    match /matches/{matchId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.users;
      allow write: if isAuthenticated();
    }
    
    // ================================
    // ================================
    // QUEST4COUPLE - COLEÇÕES ESPECÍFICAS
    // ================================
    // ================================
    
    // ================================
    // ARTIGOS PERSONALIZADOS (quest4couple_articles)
    // ================================
    match /quest4couple_articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ================================
    // COMENTÁRIOS (quest4couple_comments)
    // ================================
    match /quest4couple_comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // TÓPICOS DO FÓRUM (quest4couple_topics)
    // ================================
    match /quest4couple_topics/{topicId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // RESPOSTAS DO FÓRUM (quest4couple_replies)
    // ================================
    match /quest4couple_replies/{replyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ================================
    // CHAT PÚBLICO (quest4couple_chat)
    // ================================
    match /quest4couple_chat/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // ================================
    // CONVERSAS PRIVADAS (quest4couple_conversations)
    // ================================
    match /quest4couple_conversations/{conversationId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      allow delete: if false;
    }
    
    // ================================
    // MENSAGENS PRIVADAS (quest4couple_messages)
    // ================================
    match /quest4couple_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    // ================================
    // VALIDAÇÃO DE GÉNERO QUEST4COUPLE
    // ================================
    match /quest4couple_genderValidations/{validationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (isAdmin() || (resource.data.userId == request.auth.uid && resource.data.status == 'pending'));
      allow delete: if isAdmin();
    }
    
    // ================================
    // FEEDBACK (partilhado ou separado)
    // ================================
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    match /quest4you_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    match /quest4couple_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // ================================
    // SISTEMA DE AMIZADES (quest4you_friendships)
    // ================================
    match /quest4you_friendships/{friendshipId} {
      // Utilizadores podem ler amizades onde estão envolvidos
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
      // Utilizadores autenticados podem criar pedidos de amizade
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid;
      // Só o receiver pode aceitar/rejeitar, ou sender pode cancelar
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.receiverId || 
         request.auth.uid == resource.data.senderId);
      // Ambos podem remover a amizade
      allow delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
    }
    
    // Sub-coleção para lista de amigos (cache rápido)
    match /quest4you_users/{userId}/friends/{friendId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isOwner(friendId);
    }
  }
}
